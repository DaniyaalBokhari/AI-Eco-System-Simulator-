"""
algorithms.py
=============
Four optimization algorithms implemented from scratch (no scikit-learn).

1. Genetic Algorithm (GA)
   - 50 individuals, tournament selection (k=3), uniform crossover, 10% Gaussian mutation
2. Particle Swarm Optimization (PSO)
   - 30 particles, w=0.7, c1=1.5, c2=1.5
3. Neural Network (NN)
   - Architecture: 20-64-32-1, ReLU hidden, Linear output
   - Trained via mini-batch gradient descent (backpropagation from scratch)
4. Decision Tree (Entropy / Information Gain)
   - Max depth 5, extracts human-readable IF/THEN rules

All algorithms optimise the ecosystem fitness function defined in ecosystem.py.

Author: AI Ecosystem Team
"""

import numpy as np
import random
import math
import json
import pickle
from typing import Dict, List, Optional, Tuple, Callable

from ecosystem import (
    DEFAULT_PARAMS, PARAM_BOUNDS, PARAM_KEYS, evaluate_params
)


# ===========================================================================
# Utility helpers
# ===========================================================================

def params_to_vector(params: Dict[str, float]) -> List[float]:
    return [params[k] for k in PARAM_KEYS]

def vector_to_params(vec: List[float]) -> Dict[str, float]:
    return dict(zip(PARAM_KEYS, vec))

def clip_vector(vec: List[float]) -> List[float]:
    out = []
    for k, v in zip(PARAM_KEYS, vec):
        lo, hi = PARAM_BOUNDS[k]
        out.append(max(lo, min(hi, v)))
    return out

def random_vector() -> List[float]:
    vec = []
    for k in PARAM_KEYS:
        lo, hi = PARAM_BOUNDS[k]
        vec.append(random.uniform(lo, hi))
    return vec

DIM = len(PARAM_KEYS)


# ===========================================================================
# 1. Genetic Algorithm
# ===========================================================================

class GeneticAlgorithm:
    """
    Genetic Algorithm for ecosystem parameter optimisation.

    Configuration
    -------------
    pop_size          : 50 individuals
    tournament_size   : 3
    crossover_type    : uniform (each gene from parent A or B with p=0.5)
    mutation_rate     : 0.10  (10% of genes mutated per individual)
    mutation_strength : 0.05  (Gaussian std as fraction of parameter range)
    elitism           : top 2 individuals always survive
    """

    def __init__(
        self,
        grid_size: int = 20,
        pop_size: int = 50,
        tournament_size: int = 3,
        mutation_rate: float = 0.10,
        mutation_strength: float = 0.05,
        elitism: int = 2,
        max_steps: int = 120,
        callback: Optional[Callable] = None,
    ):
        self.grid_size       = grid_size
        self.pop_size        = pop_size
        self.tournament_size = tournament_size
        self.mutation_rate   = mutation_rate
        self.mutation_strength = mutation_strength
        self.elitism         = elitism
        self.max_steps       = max_steps
        self.callback        = callback  # called with (gen, best_fitness) each generation

        # State
        self.population: List[List[float]] = []
        self.fitnesses:  List[float]       = []
        self.best_individual: List[float]  = []
        self.best_fitness: float           = -np.inf
        self.history: List[Dict]           = []  # per-generation stats

    # ------------------------------------------------------------------

    def _evaluate_all(self) -> List[float]:
        """Evaluate fitness for every individual in the population."""
        fits = []
        for ind in self.population:
            result = evaluate_params(ind, grid_size=self.grid_size, max_steps=self.max_steps)
            fits.append(result["fitness"])
        return fits

    def _tournament_select(self) -> List[float]:
        """Select one individual via tournament selection."""
        candidates = random.sample(range(self.pop_size), self.tournament_size)
        best_idx = max(candidates, key=lambda i: self.fitnesses[i])
        return list(self.population[best_idx])

    def _uniform_crossover(self, parent_a: List[float], parent_b: List[float]) -> List[float]:
        """Uniform crossover: each gene is taken from A or B with equal probability."""
        child = []
        for ga, gb in zip(parent_a, parent_b):
            child.append(ga if random.random() < 0.5 else gb)
        return child

    def _mutate(self, individual: List[float]) -> List[float]:
        """
        Apply Gaussian mutation to each gene with probability mutation_rate.
        Mutation std = mutation_strength × (param_range).
        """
        mutated = []
        for i, (k, v) in enumerate(zip(PARAM_KEYS, individual)):
            if random.random() < self.mutation_rate:
                lo, hi = PARAM_BOUNDS[k]
                std = self.mutation_strength * (hi - lo)
                v = v + random.gauss(0, std)
                v = max(lo, min(hi, v))
            mutated.append(v)
        return mutated

    # ------------------------------------------------------------------

    def run(self, n_generations: int = 30) -> Dict:
        """
        Execute the genetic algorithm.

        Parameters
        ----------
        n_generations : int
            Number of generations to evolve.

        Returns
        -------
        dict with best_params, best_fitness, history
        """
        # Initialise population
        self.population = [random_vector() for _ in range(self.pop_size)]
        self.fitnesses  = self._evaluate_all()

        for gen in range(n_generations):
            # Track best
            gen_best_idx = int(np.argmax(self.fitnesses))
            if self.fitnesses[gen_best_idx] > self.best_fitness:
                self.best_fitness    = self.fitnesses[gen_best_idx]
                self.best_individual = list(self.population[gen_best_idx])

            gen_stats = {
                "generation":  gen,
                "best":        self.best_fitness,
                "mean":        float(np.mean(self.fitnesses)),
                "worst":       float(np.min(self.fitnesses)),
                "std":         float(np.std(self.fitnesses)),
            }
            self.history.append(gen_stats)

            if self.callback:
                self.callback(gen, self.best_fitness, gen_stats)

            # Elitism: preserve top individuals
            elite_indices = sorted(
                range(self.pop_size), key=lambda i: self.fitnesses[i], reverse=True
            )[:self.elitism]
            new_population = [list(self.population[i]) for i in elite_indices]

            # Fill rest via selection + crossover + mutation
            while len(new_population) < self.pop_size:
                p1 = self._tournament_select()
                p2 = self._tournament_select()
                child = self._uniform_crossover(p1, p2)
                child = self._mutate(child)
                new_population.append(child)

            self.population = new_population
            self.fitnesses  = self._evaluate_all()

        # Final best
        gen_best_idx = int(np.argmax(self.fitnesses))
        if self.fitnesses[gen_best_idx] > self.best_fitness:
            self.best_fitness    = self.fitnesses[gen_best_idx]
            self.best_individual = list(self.population[gen_best_idx])

        return {
            "best_params":  vector_to_params(self.best_individual),
            "best_fitness": self.best_fitness,
            "history":      self.history,
        }


# ===========================================================================
# 2. Particle Swarm Optimization
# ===========================================================================

class ParticleSwarmOptimization:
    """
    Particle Swarm Optimization for ecosystem parameter search.

    Configuration
    -------------
    n_particles : 30
    w           : 0.7   (inertia weight)
    c1          : 1.5   (cognitive coefficient)
    c2          : 1.5   (social coefficient)
    v_max       : 20% of each parameter's range
    """

    def __init__(
        self,
        grid_size: int = 20,
        n_particles: int = 30,
        w: float  = 0.7,
        c1: float = 1.5,
        c2: float = 1.5,
        max_steps: int = 120,
        callback: Optional[Callable] = None,
    ):
        self.grid_size   = grid_size
        self.n_particles = n_particles
        self.w  = w
        self.c1 = c1
        self.c2 = c2
        self.max_steps = max_steps
        self.callback  = callback

        # Compute velocity bounds per dimension
        self.v_max = np.array([
            0.20 * (PARAM_BOUNDS[k][1] - PARAM_BOUNDS[k][0])
            for k in PARAM_KEYS
        ])
        self.lo = np.array([PARAM_BOUNDS[k][0] for k in PARAM_KEYS])
        self.hi = np.array([PARAM_BOUNDS[k][1] for k in PARAM_KEYS])

        # State
        self.positions: np.ndarray = None  # (n_particles, DIM)
        self.velocities: np.ndarray = None
        self.pbest_pos: np.ndarray = None  # personal bests
        self.pbest_fit: np.ndarray = None
        self.gbest_pos: np.ndarray = None  # global best
        self.gbest_fit: float = -np.inf
        self.history: List[Dict] = []

    # ------------------------------------------------------------------

    def _evaluate(self, pos: np.ndarray) -> float:
        result = evaluate_params(list(pos), grid_size=self.grid_size, max_steps=self.max_steps)
        return result["fitness"]

    def _evaluate_all(self) -> np.ndarray:
        return np.array([self._evaluate(self.positions[i]) for i in range(self.n_particles)])

    # ------------------------------------------------------------------

    def run(self, n_iterations: int = 40) -> Dict:
        """
        Execute PSO.

        Parameters
        ----------
        n_iterations : int

        Returns
        -------
        dict with best_params, best_fitness, history
        """
        # Initialise positions uniformly within bounds
        self.positions  = self.lo + np.random.rand(self.n_particles, DIM) * (self.hi - self.lo)
        self.velocities = (np.random.rand(self.n_particles, DIM) - 0.5) * 2 * self.v_max

        fitnesses = self._evaluate_all()

        self.pbest_pos = self.positions.copy()
        self.pbest_fit = fitnesses.copy()

        gbest_idx = int(np.argmax(fitnesses))
        self.gbest_pos = self.positions[gbest_idx].copy()
        self.gbest_fit = float(fitnesses[gbest_idx])

        for it in range(n_iterations):
            # Update velocity and position for each particle
            r1 = np.random.rand(self.n_particles, DIM)
            r2 = np.random.rand(self.n_particles, DIM)

            # v = w*v + c1*r1*(pbest - x) + c2*r2*(gbest - x)
            self.velocities = (
                self.w * self.velocities
                + self.c1 * r1 * (self.pbest_pos - self.positions)
                + self.c2 * r2 * (self.gbest_pos - self.positions)
            )
            # Clamp velocities
            self.velocities = np.clip(self.velocities, -self.v_max, self.v_max)

            # Update positions and clamp to bounds
            self.positions = self.positions + self.velocities
            self.positions = np.clip(self.positions, self.lo, self.hi)

            # Evaluate
            fitnesses = self._evaluate_all()

            # Update personal bests
            for i in range(self.n_particles):
                if fitnesses[i] > self.pbest_fit[i]:
                    self.pbest_fit[i] = fitnesses[i]
                    self.pbest_pos[i] = self.positions[i].copy()

            # Update global best
            gbest_idx = int(np.argmax(self.pbest_fit))
            if self.pbest_fit[gbest_idx] > self.gbest_fit:
                self.gbest_fit = float(self.pbest_fit[gbest_idx])
                self.gbest_pos = self.pbest_pos[gbest_idx].copy()

            stats = {
                "iteration": it,
                "best":  self.gbest_fit,
                "mean":  float(np.mean(fitnesses)),
                "worst": float(np.min(fitnesses)),
                "std":   float(np.std(fitnesses)),
            }
            self.history.append(stats)

            if self.callback:
                self.callback(it, self.gbest_fit, stats)

        return {
            "best_params":  vector_to_params(self.gbest_pos.tolist()),
            "best_fitness": self.gbest_fit,
            "history":      self.history,
        }



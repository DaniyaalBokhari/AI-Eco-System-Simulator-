    def _rp_spinbox(self, parent, label, var, lo, hi):
        fr = tk.Frame(parent, bg=BG_PANEL)
        fr.pack(fill="x", padx=8, pady=2)
        tk.Label(fr, text=label, bg=BG_PANEL, fg=FG_DIM,
                 font=("Segoe UI", 8), anchor="w").pack(anchor="w")
        ttk.Spinbox(fr, from_=lo, to=hi, textvariable=var,
                    width=6, font=("Consolas", 9)).pack(anchor="w")

    def _update_right_panel(self):
        """Update live metric labels from current ecosystem state."""
        if self._ecosystem is None:
            return
        eco = self._ecosystem
        self._lbl_plants.config( text=str(len(eco.plants)))
        self._lbl_herbs.config(  text=str(len(eco.herbivores)))
        self._lbl_carns.config(  text=str(len(eco.carnivores)))
        self._lbl_step.config(   text=str(eco.step_count))
        fit = eco.fitness()
        div = eco.shannon_diversity()
        stb = eco.stability_score()
        self._lbl_fitness.config(text=f"{fit:.4f}")
        self._lbl_div.config(    text=f"{div:.4f}")
        self._lbl_stab.config(   text=f"{stb:.4f}")

    # ======================================================================
    # Simulation control
    # ======================================================================

    def _start_sim(self):
        if self._sim_running:
            return
        gs     = self.grid_size.get()
        params = self._get_params()
        self._ecosystem = Ecosystem(grid_size=gs, params=params, max_steps=120)

        # Reset history buffers
        self._pop_history = {"plants": [], "herbivores": [], "carnivores": [], "steps": []}
        self._fit_history  = []
        self._div_history  = []
        self._stab_history = []

        self._sim_running = True
        self._sim_thread  = threading.Thread(target=self._sim_loop, daemon=True)
        self._sim_thread.start()
        self._set_status("Simulation running…")

    def _sim_loop(self):
        """Background simulation loop, updates GUI via self.after."""
        eco   = self._ecosystem
        speed = self.sim_speed_var

        while self._sim_running and eco.step_count < eco.max_steps and eco.is_alive():
            eco.step()
            step = eco.step_count

            # Snapshot for GUI update
            grid  = eco.get_grid_state()
            np_c  = len(eco.plants)
            nh_c  = len(eco.herbivores)
            nc_c  = len(eco.carnivores)
            fit   = eco.fitness()
            div   = eco.shannon_diversity()
            stab  = eco.stability_score()

            self._pop_history["plants"].append(np_c)
            self._pop_history["herbivores"].append(nh_c)
            self._pop_history["carnivores"].append(nc_c)
            self._pop_history["steps"].append(step)
            self._fit_history.append(fit)
            self._div_history.append(div)
            self._stab_history.append(stab)

            # Schedule GUI update on main thread
            self.after(0, self._gui_sim_update, grid.copy(), fit, div, stab)

            time.sleep(speed.get())

        # Done
        self._sim_running = False
        reason = "Extinction" if not eco.is_alive() else "Max steps reached"
        self.after(0, self._set_status,
                   f"Simulation ended – {reason}. Survival: {eco.step_count} months")

    def _gui_sim_update(self, grid, fit, div, stab):
        """Called on main thread to refresh grid and graphs."""
        self._draw_grid(grid)
        self._update_right_panel()
        # Throttle graph updates (every 3 steps)
        if len(self._pop_history["steps"]) % 3 == 0:
            self._update_graphs()

    def _stop_sim(self):
        self._sim_running = False
        self._set_status("Simulation stopped.")

    # ======================================================================
    # Algorithm optimisation
    # ======================================================================

    def _run_algo(self):
        if self._algo_thread and self._algo_thread.is_alive():
            messagebox.showinfo("Busy", "An algorithm is already running.")
            return

        algo = self.algorithm_var.get()
        gs   = self.grid_size.get()
        self._fit_history = []
        self._nb.select(self._tab_algo)
        self._set_status(f"Running {algo}…")
        self._algo_start_time = time.time()

        if algo == "GA":
            n_gen = self._ga_gen_var.get()

            def _run():
                def _cb(gen, best, stats):
                    self._fit_history.append(best)
                    self.after(0, self._algo_tick, gen, best)
                ga = GeneticAlgorithm(grid_size=gs, pop_size=50, callback=_cb)
                return ga.run(n_generations=n_gen)

        elif algo == "PSO":
            n_iter = self._pso_iter_var.get()

            def _run():
                def _cb(it, best, stats):
                    self._fit_history.append(best)
                    self.after(0, self._algo_tick, it, best)
                pso = ParticleSwarmOptimization(grid_size=gs, n_particles=30, callback=_cb)
                return pso.run(n_iterations=n_iter)

        elif algo == "Neural Network":
            n_ep = self._nn_epoch_var.get()

            def _run():
                X, y = generate_training_data(400, grid_size=gs, verbose=False)
                nn = NeuralNetwork(learning_rate=0.002)
                nn.fit(X, y, epochs=n_ep)
                for h in nn.train_history:
                    self._fit_history.append(1.0 - h["loss"])
                    self.after(0, self._algo_tick, h["epoch"],
                               round(1.0 - h["loss"], 4))
                return {"best_fitness": float(max(self._fit_history)),
                        "best_params": {}, "history": nn.train_history}

        elif algo == "Decision Tree":
            def _run():
                X, y_raw = generate_training_data(300, grid_size=gs, verbose=False)
                y = (y_raw > 60).astype(int)
                dt = DecisionTree(max_depth=5)
                dt.fit(X, y)
                acc = dt.accuracy(X, y)
                self._fit_history = [acc]
                self.after(0, self._algo_tick, 0, acc)
                return {"best_fitness": acc, "best_params": {},
                        "rules": dt.get_rules(), "accuracy": acc}

        self._algo_thread = WorkerThread(_run, q=self._algo_queue)
        self._algo_thread.start()

    def _algo_tick(self, iteration, best):
        """Called from main thread during algorithm iterations."""
        elapsed = time.time() - self._algo_start_time
        self._lbl_algo_best.config(text=f"{best:.4f}")
        self._lbl_algo_iter.config(text=str(iteration + 1))
        self._lbl_algo_time.config(text=f"{elapsed:.1f}s")
        self._update_algo_graph()

    def _after_poll_algo(self):
        """Poll algorithm result queue."""
        try:
            status, result = self._algo_queue.get_nowait()
            if status == "done":
                self._algo_done(result)
            else:
                messagebox.showerror("Algorithm Error", str(result))
                self._set_status("Algorithm error.")
        except queue.Empty:
            pass
        self.after(300, self._after_poll_algo)

    def _algo_done(self, result):
        bf = result.get("best_fitness", 0)
        self._set_status(f"Optimisation complete. Best fitness: {bf:.4f}")

        # Show best params
        bp = result.get("best_params", {})
        if bp:
            txt = "\n".join(f"{k}: {v:.3f}" for k, v in list(bp.items())[:15])
            self._best_txt.config(state="normal")
            self._best_txt.delete("1.0", "end")
            self._best_txt.insert("end", txt)
            self._best_txt.config(state="disabled")

            # Apply best params to sliders
            for k, v in bp.items():
                if k in self.param_vars:
                    self.param_vars[k].set(round(v, 4))

        # Show rules for DT
        if "rules" in result:
            self._exp_log_append("\n=== Decision Tree Rules ===")
            for i, rule in enumerate(result["rules"][:8], 1):
                self._exp_log_append(f"\nRule {i}:\n{rule}")

    # ======================================================================
    # GA vs PSO Comparison
    # ======================================================================

    def _run_comparison(self):
        """Run both GA and PSO and overlay their convergence curves."""
        if self._algo_thread and self._algo_thread.is_alive():
            messagebox.showinfo("Busy", "Wait for current algorithm to finish.")
            return

        gs     = self.grid_size.get()
        n_gen  = self._ga_gen_var.get()
        n_iter = self._pso_iter_var.get()
        self._algo_conv = {"GA": [], "PSO": []}
        self._nb.select(self._tab_algo)
        self._set_status("Running GA vs PSO comparison…")

        def _run():
            # GA
            def _ga_cb(gen, best, stats):
                self._algo_conv["GA"].append(best)
                self.after(0, self._update_algo_graph)
            ga = GeneticAlgorithm(grid_size=gs, pop_size=50, callback=_ga_cb)
            ga.run(n_generations=n_gen)

            # PSO
            def _pso_cb(it, best, stats):
                self._algo_conv["PSO"].append(best)
                self.after(0, self._update_algo_graph)
            pso = ParticleSwarmOptimization(grid_size=gs, n_particles=30, callback=_pso_cb)
            pso.run(n_iterations=n_iter)

            return {"GA_best": max(self._algo_conv["GA"]),
                    "PSO_best": max(self._algo_conv["PSO"])}

        self._algo_thread = WorkerThread(_run, q=self._algo_queue)
        self._algo_thread.start()

    # ======================================================================
    # Experiments
    # ======================================================================

    def _run_experiments(self):
        self._nb.select(self._tab_exp)
        self._exp_log_append("=" * 55)
        self._exp_log_append("Starting All Experiments (quick mode)…")
        self._exp_log_append("=" * 55)

        gs = self.grid_size.get()

        def _run():
            return run_all_experiments(
                grid_size=gs,
                quick_mode=True,
                callback=lambda msg: self.after(0, self._exp_log_append, msg),
            )

        self._algo_thread = WorkerThread(_run, q=self._exp_queue)
        self._algo_thread.start()

    def _after_poll_exp(self):
        try:
            status, result = self._exp_queue.get_nowait()
            if status == "done":
                self._experiments_done(result)
            else:
                self._exp_log_append(f"ERROR: {result}")
        except queue.Empty:
            pass
        self.after(400, self._after_poll_exp)

    def _experiments_done(self, results):
        self._exp_log_append("\n✓ Experiments complete!\n")
        summary = results.get("summary", {})
        if summary:
            self._exp_log_append("=== SUMMARY ===")
            for k, v in summary.items():
                self._exp_log_append(f"  {k}: {v}")

        self._set_status("All experiments done. Results saved to /results/")

    # ======================================================================
    # Export helpers
    # ======================================================================

    def _export_graph(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".png",
            filetypes=[("PNG Image", "*.png"), ("All Files", "*.*")],
            title="Save Graph",
        )
        if not path:
            return
        # Save the currently visible figure
        tab = self._nb.index(self._nb.select())
        if tab == 1:
            self._fig_pop.savefig(path, dpi=150, facecolor=BG_DARK)
        elif tab == 2:
            self._fig_algo.savefig(path, dpi=150, facecolor=BG_DARK)
        else:
            messagebox.showinfo("Export", "Switch to Populations or Optimisation tab first.")
            return
        messagebox.showinfo("Saved", f"Graph saved to:\n{path}")

    def _export_csv(self):
        path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV", "*.csv")],
            title="Save Data",
        )
        if not path:
            return
        steps = self._pop_history["steps"]
        if not steps:
            messagebox.showinfo("No data", "Run a simulation first.")
            return
        with open(path, "w", newline="") as f:
            writer = csv.writer(f)
            writer.writerow(["step", "plants", "herbivores", "carnivores",
                             "fitness", "diversity", "stability"])
            for i, s in enumerate(steps):
                writer.writerow([
                    s,
                    self._pop_history["plants"][i],
                    self._pop_history["herbivores"][i],
                    self._pop_history["carnivores"][i],
                    round(self._fit_history[i], 5) if i < len(self._fit_history) else "",
                    round(self._div_history[i], 5)  if i < len(self._div_history) else "",
                    round(self._stab_history[i], 5) if i < len(self._stab_history) else "",
                ])
        messagebox.showinfo("Saved", f"Data saved to:\n{path}")

    def _export_report(self):
        results_dir = os.path.join(os.path.dirname(__file__), "results")
        path = filedialog.asksaveasfilename(
            defaultextension=".json",
            filetypes=[("JSON", "*.json")],
            initialdir=results_dir,
            title="Save Report",
        )
        if not path:
            return
        data = {
            "simulation_history": self._pop_history,
            "fitness_history": [round(v, 5) for v in self._fit_history],
            "diversity_history": [round(v, 5) for v in self._div_history],
            "stability_history": [round(v, 5) for v in self._stab_history],
            "parameters": self._get_params(),
            "grid_size": self.grid_size.get(),
            "algorithm": self.algorithm_var.get(),
        }
        with open(path, "w") as f:
            json.dump(data, f, indent=2)
        messagebox.showinfo("Saved", f"Report saved to:\n{path}")

    # ======================================================================
    # Utility
    # ======================================================================

    def _set_status(self, msg: str):
        self._status_var.set(msg)

    def _show_about(self):

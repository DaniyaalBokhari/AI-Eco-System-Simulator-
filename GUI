    # ------------------------------------------------------------------
    # Grid tab
    # ------------------------------------------------------------------

    def _build_grid_tab(self):
        parent = self._tab_grid

        # Legend
        leg = tk.Frame(parent, bg=BG_DARK)
        leg.pack(side="bottom", pady=4)
        for label, color in [("Empty", "#1a1a2e"), ("Plant 🌱", "#2d6a4f"),
                              ("Herbivore 🐇", "#4361ee"), ("Carnivore 🦁", "#e94560")]:
            tk.Label(leg, text="  ", bg=color, width=2).pack(side="left", padx=1)
            tk.Label(leg, text=label, bg=BG_DARK, fg=FG_DIM,
                     font=("Segoe UI", 9)).pack(side="left", padx=(0, 12))

        # Canvas for pixel grid
        self._grid_canvas = tk.Canvas(parent, bg="#1a1a2e",
                                      highlightthickness=0)
        self._grid_canvas.pack(fill="both", expand=True, padx=4, pady=4)
        self._grid_canvas.bind("<Configure>", self._on_grid_resize)

        self._cell_size = 20
        self._grid_image_refs = []   # keep refs to avoid GC

    def _on_grid_resize(self, event):
        gs = self.grid_size.get()
        self._cell_size = max(2, min(
            event.width  // gs,
            event.height // gs,
        ))

    def _draw_grid(self, grid: np.ndarray):
        """Draw the ecosystem grid on the canvas."""
        c  = self._grid_canvas
        cs = self._cell_size
        c.delete("all")
        gs = grid.shape[0]
        for r in range(gs):
            for col in range(gs):
                val = int(grid[r, col])
                # Respect visibility toggles
                if val == 1 and not self.show_plants.get():
                    val = 0
                if val == 2 and not self.show_herbs.get():
                    val = 0
                if val == 3 and not self.show_carns.get():
                    val = 0
                color = GRID_COLORS.get(val, "#000000")
                x0, y0 = col * cs, r * cs
                c.create_rectangle(x0, y0, x0 + cs, y0 + cs,
                                   fill=color, outline="", tags="cell")

    # ------------------------------------------------------------------
    # Population graphs tab
    # ------------------------------------------------------------------

    def _build_graphs_tab(self):
        fig = Figure(figsize=(8, 5), facecolor=BG_DARK)
        self._ax_pop  = fig.add_subplot(221, facecolor=BG_PANEL)
        self._ax_div  = fig.add_subplot(222, facecolor=BG_PANEL)
        self._ax_stab = fig.add_subplot(223, facecolor=BG_PANEL)
        self._ax_fit  = fig.add_subplot(224, facecolor=BG_PANEL)
        fig.tight_layout(pad=2.5)

        for ax in (self._ax_pop, self._ax_div, self._ax_stab, self._ax_fit):
            ax.tick_params(colors=FG_DIM, labelsize=7)
            for spine in ax.spines.values():
                spine.set_edgecolor(BG_CARD)
            ax.set_facecolor(BG_PANEL)

        self._canvas_pop = FigureCanvasTkAgg(fig, master=self._tab_graphs)
        self._canvas_pop.get_tk_widget().pack(fill="both", expand=True)
        self._fig_pop = fig

    def _update_graphs(self):
        """Refresh all population graphs with current history."""
        steps = self._pop_history["steps"]

        for ax in (self._ax_pop, self._ax_div, self._ax_stab, self._ax_fit):
            ax.clear()
            ax.set_facecolor(BG_PANEL)
            ax.tick_params(colors=FG_DIM, labelsize=7)
            for spine in ax.spines.values():
                spine.set_edgecolor(BG_CARD)

        if steps:
            # Population
            ax = self._ax_pop
            ax.plot(steps, self._pop_history["plants"],
                    color="#2d6a4f", label="Plants", linewidth=1.2)
            ax.plot(steps, self._pop_history["herbivores"],
                    color="#4361ee", label="Herbivores", linewidth=1.2)
            ax.plot(steps, self._pop_history["carnivores"],
                    color="#e94560", label="Carnivores", linewidth=1.2)
            ax.set_title("Population Dynamics", color=FG_LIGHT, fontsize=9)
            ax.set_xlabel("Month", color=FG_DIM, fontsize=7)
            ax.legend(fontsize=7, facecolor=BG_PANEL, labelcolor=FG_LIGHT)

            # Diversity
            self._ax_div.plot(steps, self._div_history,
                              color=GREEN, linewidth=1.2)
            self._ax_div.set_title("Shannon Diversity", color=FG_LIGHT, fontsize=9)
            self._ax_div.set_ylim(0, 1.05)
            self._ax_div.set_xlabel("Month", color=FG_DIM, fontsize=7)
            self._ax_div.axhline(0.8, color=YELLOW, linestyle="--", linewidth=0.8)

            # Stability
            self._ax_stab.plot(steps, self._stab_history,
                               color=YELLOW, linewidth=1.2)
            self._ax_stab.set_title("Population Stability", color=FG_LIGHT, fontsize=9)
            self._ax_stab.set_ylim(0, 1.05)
            self._ax_stab.set_xlabel("Month", color=FG_DIM, fontsize=7)

            # Fitness
            self._ax_fit.plot(steps, self._fit_history,
                              color=ACCENT, linewidth=1.2)
            self._ax_fit.set_title("Ecosystem Fitness", color=FG_LIGHT, fontsize=9)
            self._ax_fit.set_ylim(0, 1.05)
            self._ax_fit.set_xlabel("Month", color=FG_DIM, fontsize=7)

        self._fig_pop.tight_layout(pad=2.5)
        self._canvas_pop.draw()

    # ------------------------------------------------------------------
    # Optimisation tab
    # ------------------------------------------------------------------

    def _build_algo_tab(self):
        parent = self._tab_algo

        fig = Figure(figsize=(8, 5), facecolor=BG_DARK)
        self._ax_conv  = fig.add_subplot(121, facecolor=BG_PANEL)
        self._ax_comp  = fig.add_subplot(122, facecolor=BG_PANEL)
        fig.tight_layout(pad=2.5)

        for ax in (self._ax_conv, self._ax_comp):
            ax.tick_params(colors=FG_DIM, labelsize=7)
            for sp in ax.spines.values():
                sp.set_edgecolor(BG_CARD)

        self._canvas_algo = FigureCanvasTkAgg(fig, master=parent)
        self._canvas_algo.get_tk_widget().pack(fill="both", expand=True)
        self._fig_algo = fig

        # Metrics row below
        met = tk.Frame(parent, bg=BG_PANEL)
        met.pack(fill="x", padx=4, pady=4)
        self._lbl_algo_best  = self._metric_label(met, "Best Fitness", "—")
        self._lbl_algo_iter  = self._metric_label(met, "Iteration",    "—")
        self._lbl_algo_time  = self._metric_label(met, "Elapsed",      "—")

    def _metric_label(self, parent, title, val):
        frame = tk.Frame(parent, bg=BG_CARD, padx=8, pady=4)
        frame.pack(side="left", padx=4)
        tk.Label(frame, text=title, bg=BG_CARD, fg=FG_DIM,
                 font=("Segoe UI", 8)).pack()
        lbl = tk.Label(frame, text=val, bg=BG_CARD, fg=FG_LIGHT,
                       font=("Segoe UI", 11, "bold"))
        lbl.pack()
        return lbl

    def _update_algo_graph(self):
        for ax in (self._ax_conv, self._ax_comp):
            ax.clear()
            ax.set_facecolor(BG_PANEL)
            ax.tick_params(colors=FG_DIM, labelsize=7)
            for sp in ax.spines.values():
                sp.set_edgecolor(BG_CARD)

        # Convergence
        ax = self._ax_conv
        if self._fit_history:
            ax.plot(self._fit_history, color=ACCENT, linewidth=1.4, label="Fitness")
        ax.set_title(f"Fitness Convergence – {self.algorithm_var.get()}",
                     color=FG_LIGHT, fontsize=9)
        ax.set_xlabel("Iteration", color=FG_DIM, fontsize=7)
        ax.set_ylabel("Fitness", color=FG_DIM, fontsize=7)

        # GA vs PSO comparison
        ax2 = self._ax_comp
        if self._algo_conv["GA"]:
            ax2.plot(self._algo_conv["GA"],  color="#4361ee", label="GA",  linewidth=1.2)
        if self._algo_conv["PSO"]:
            ax2.plot(self._algo_conv["PSO"], color=YELLOW,    label="PSO", linewidth=1.2)
        ax2.set_title("GA vs PSO Comparison", color=FG_LIGHT, fontsize=9)
        ax2.set_xlabel("Iteration", color=FG_DIM, fontsize=7)
        ax2.legend(fontsize=7, facecolor=BG_PANEL, labelcolor=FG_LIGHT)

        self._fig_algo.tight_layout(pad=2.5)
        self._canvas_algo.draw()


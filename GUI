    def _rp_metric(self, parent, label, val):
        fr = tk.Frame(parent, bg=BG_PANEL)
        fr.pack(fill="x", padx=8, pady=1)
        tk.Label(fr, text=label + ":", bg=BG_PANEL, fg=FG_DIM,
                 font=("Segoe UI", 9), width=12, anchor="w").pack(side="left")
        lbl = tk.Label(fr, text=val, bg=BG_PANEL, fg=FG_LIGHT,
                       font=("Segoe UI", 9, "bold"), anchor="e")

    def _build_param_panel(self, parent):
        tk.Label(parent, text="Parameters", bg=BG_PANEL, fg=ACCENT,
                 font=("Segoe UI", 11, "bold")).pack(pady=(10, 2))

        canvas = tk.Canvas(parent, bg=BG_PANEL, highlightthickness=0)
        sb = ttk.Scrollbar(parent, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=sb.set)
        sb.pack(side="right", fill="y")
        canvas.pack(side="left", fill="both", expand=True)

        inner = tk.Frame(canvas, bg=BG_PANEL)
        canvas.create_window((0, 0), window=inner, anchor="nw")
        inner.bind("<Configure>",
                   lambda e: canvas.configure(scrollregion=canvas.bbox("all")))

        # Group parameters
        groups = {
            "🌱 Plants":      [k for k in PARAM_KEYS if "plant" in k or "init_plant" in k],
            "🐇 Herbivores":  [k for k in PARAM_KEYS if "herb" in k or "init_herb" in k],
            "🦁 Carnivores":  [k for k in PARAM_KEYS if "carn" in k or "init_carn" in k],
            "🌍 Environment": [k for k in PARAM_KEYS if k in
                               ("season_amplitude", "hemisphere", "carrying_capacity")],
        }

        for grp_name, keys in groups.items():
            tk.Label(inner, text=grp_name, bg=BG_PANEL, fg=GREEN,
                     font=("Segoe UI", 9, "bold")).pack(anchor="w", padx=8, pady=(8, 2))
            for k in keys:
                self._add_slider(inner, k)

        # Reset button
        tk.Button(inner, text="Reset Defaults", command=self._reset_params,
                  bg=BG_CARD, fg=FG_LIGHT, relief="flat", cursor="hand2",
                  font=("Segoe UI", 9)).pack(pady=10, padx=8, fill="x")

    def _add_slider(self, parent, key: str):
        lo, hi = PARAM_BOUNDS[key]
        var = tk.DoubleVar(value=DEFAULT_PARAMS[key])
        self.param_vars[key] = var

        frame = tk.Frame(parent, bg=BG_PANEL)
        frame.pack(fill="x", padx=6, pady=1)

        label_text = key.replace("_", " ").title()
        tk.Label(frame, text=label_text, bg=BG_PANEL, fg=FG_DIM,
                 font=("Segoe UI", 8), anchor="w", width=18,
                 wraplength=120).pack(side="left")

        val_lbl = tk.Label(frame, textvariable=var, bg=BG_PANEL, fg=FG_LIGHT,
                           font=("Consolas", 8), width=5, anchor="e")
        val_lbl.pack(side="right")

        # Format label nicely
        def _fmt_trace(*_):
            val_lbl.config(text=f"{var.get():.2f}")
        var.trace_add("write", _fmt_trace)

        sl = tk.Scale(parent, from_=lo, to=hi,
                      resolution=(hi - lo) / 200,
                      variable=var, orient="horizontal",
                      length=200, bg=BG_PANEL, fg=FG_LIGHT,
                      troughcolor=BG_CARD, highlightthickness=0,
                      showvalue=False, sliderlength=10)
        sl.pack(padx=6)

    def _reset_params(self):
        for k, var in self.param_vars.items():
            var.set(DEFAULT_PARAMS[k])

    def _get_params(self) -> Dict[str, float]:
        return {k: var.get() for k, var in self.param_vars.items()}


# ---------------------------------------------------------------------------
# Utility: run function in background thread, report via queue
# ---------------------------------------------------------------------------

class WorkerThread(threading.Thread):
    """Generic background worker with result queue."""

    def __init__(self, fn, args=(), kwargs=None, q: queue.Queue = None):
        super().__init__(daemon=True)
        self.fn     = fn
        self.args   = args
        self.kwargs = kwargs or {}
        self.q      = q or queue.Queue()

    def run(self):
        try:
            result = self.fn(*self.args, **self.kwargs)
            self.q.put(("done", result))
        except Exception as e:
            import traceback
            self.q.put(("error", str(e) + "\n" + traceback.format_exc()))



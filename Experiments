# Experiment 2: Parameter Sensitivity Analysis
# ===========================================================================

def experiment_sensitivity(
    grid_size: int = 20,
    n_samples: int = 200,
    callback: Optional[Callable] = None,
) -> Dict:
    """
    Identify which parameters most influence ecosystem survival.

    Method: One-at-a-time (OAT) sensitivity analysis.
    For each parameter, vary it across its full range while holding
    others at default values. Record fitness variance.

    Also computes Pearson correlation between each parameter and fitness.
    """

    def _cb(msg):
        if callback:
            callback(msg)

    default_vec = [DEFAULT_PARAMS[k] for k in PARAM_KEYS]
    n_per_param = max(20, n_samples // len(PARAM_KEYS))

    sensitivities = {}
    correlations  = {}

    # --- OAT analysis ---
    for i, k in enumerate(PARAM_KEYS):
        _cb(f"Sensitivity: {k} ({i+1}/{len(PARAM_KEYS)})...")
        lo, hi = PARAM_BOUNDS[k]
        vals   = np.linspace(lo, hi, n_per_param)
        fits   = []
        for v in vals:
            vec    = list(default_vec)
            vec[i] = float(v)
            r = evaluate_params(vec, grid_size=grid_size, max_steps=60)
            fits.append(r["fitness"])

        fits_arr = np.array(fits)
        sensitivities[k] = {
            "variance":     round(float(fits_arr.var()), 6),
            "range":        round(float(fits_arr.max() - fits_arr.min()), 4),
            "mean_fitness": round(float(fits_arr.mean()), 4),
            "param_values": [round(float(v), 4) for v in vals],
            "fitnesses":    [round(float(f), 4) for f in fits],
        }

    # --- Random sampling for correlation ---
    _cb("Computing parameter correlations...")
    X_rand = np.array([random_vector() for _ in range(n_samples)])
    y_rand = np.array([
        evaluate_params(list(X_rand[i]), grid_size=grid_size, max_steps=60)["fitness"]
        for i in range(n_samples)
    ])

    for i, k in enumerate(PARAM_KEYS):
        xi = X_rand[:, i]
        corr = float(np.corrcoef(xi, y_rand)[0, 1])
        correlations[k] = round(corr, 4)

    # Rank by sensitivity (variance)
    ranked = sorted(sensitivities.items(), key=lambda x: x[1]["variance"], reverse=True)
    ranking = [k for k, _ in ranked]

    result = {
        "experiment":    "Parameter Sensitivity Analysis",
        "grid_size":     grid_size,
        "n_samples":     n_samples,
        "sensitivities": sensitivities,
        "correlations":  correlations,
        "ranking_by_variance": ranking,
        "top_5_parameters":    ranking[:5],
        "bottom_5_parameters": ranking[-5:],
    }

    _save("exp2_sensitivity", result)
    return result



# ---------------------------------------------------------------------------
# Helper: Welch's t-test (from scratch, no scipy required for core logic)
# ---------------------------------------------------------------------------

def welch_t_test(a: List[float], b: List[float]) -> Dict:
    """
    Perform Welch's t-test between two independent samples.

    Returns
    -------
    dict with t_statistic, p_value (two-tailed), degrees_of_freedom,
              significant (bool, α=0.05)
    """
    a = np.array(a, dtype=float)
    b = np.array(b, dtype=float)
    n1, n2 = len(a), len(b)
    m1, m2 = a.mean(), b.mean()
    v1, v2 = a.var(ddof=1), b.var(ddof=1)

    se = math.sqrt(v1 / n1 + v2 / n2)
    t  = (m1 - m2) / (se + 1e-12)

    # Welch–Satterthwaite degrees of freedom
    num   = (v1 / n1 + v2 / n2) ** 2
    denom = (v1 / n1) ** 2 / (n1 - 1) + (v2 / n2) ** 2 / (n2 - 1)
    df    = num / (denom + 1e-12)

    # Two-tailed p-value approximation via regularised incomplete beta function
    # Using scipy if available, otherwise approximate
    try:
        from scipy import stats as scipy_stats
        p_value = float(2 * scipy_stats.t.sf(abs(t), df))
    except ImportError:
        # Rough normal approximation for large df
        # P(|Z| > |t|) ≈ 2*(1 - Φ(|t|))
        z = abs(t)
        p_value = float(2 * (1 - 0.5 * (1 + math.erf(z / math.sqrt(2)))))

    return {
        "t_statistic":        round(t, 4),
        "p_value":            round(p_value, 6),
        "degrees_of_freedom": round(df, 2),
        "mean_a":             round(float(m1), 4),
        "mean_b":             round(float(m2), 4),
        "std_a":              round(float(a.std(ddof=1)), 4),
        "std_b":              round(float(b.std(ddof=1)), 4),
        "significant":        bool(p_value < 0.05),
    }


def _save(name: str, data: Dict):
    """Save result dict to JSON file."""
    path = os.path.join(RESULTS_DIR, f"{name}.json")
    with open(path, "w") as f:
        json.dump(data, f, indent=2, default=str)
    return path


# ===========================================================================
# Experiment 1: GA vs PSO Comparison
# ===========================================================================

def experiment_ga_vs_pso(
    grid_size: int = 20,
    n_runs: int = 5,
    ga_generations: int = 20,
    pso_iterations: int = 25,
    callback: Optional[Callable] = None,
) -> Dict:
    """
    Compare GA and PSO across multiple independent runs.

    Metrics
    -------
    - Best fitness per run
    - Convergence speed (generation/iteration to reach 80% of final best)
    - Wall-clock time per run
    - Welch's t-test on final fitness distributions

    Parameters
    ----------
    grid_size      : ecosystem grid size for all trials
    n_runs         : number of independent replicates per algorithm
    ga_generations : GA generation budget
    pso_iterations : PSO iteration budget
    callback       : optional progress callback(msg: str)
    """

    def _cb(msg):
        if callback:
            callback(msg)

    ga_fitnesses:  List[float] = []
    pso_fitnesses: List[float] = []
    ga_histories:  List[List] = []
    pso_histories: List[List] = []
    ga_times:  List[float] = []
    pso_times: List[float] = []

    for run in range(n_runs):
        _cb(f"GA run {run+1}/{n_runs}...")
        t0 = time.time()
        ga = GeneticAlgorithm(grid_size=grid_size, pop_size=50,
                              tournament_size=3, mutation_rate=0.10)
        ga_result = ga.run(n_generations=ga_generations)
        ga_times.append(time.time() - t0)
        ga_fitnesses.append(ga_result["best_fitness"])
        ga_histories.append([h["best"] for h in ga_result["history"]])

        _cb(f"PSO run {run+1}/{n_runs}...")
        t0 = time.time()
        pso = ParticleSwarmOptimization(grid_size=grid_size, n_particles=30,
                                        w=0.7, c1=1.5, c2=1.5)
        pso_result = pso.run(n_iterations=pso_iterations)
        pso_times.append(time.time() - t0)
        pso_fitnesses.append(pso_result["best_fitness"])
        pso_histories.append([h["best"] for h in pso_result["history"]])

    # Convergence speed: first iteration reaching ≥ 80% of final best
    def convergence_speed(history: List[float]) -> int:
        target = 0.80 * history[-1]
        for i, v in enumerate(history):
            if v >= target:
                return i
        return len(history)

    ga_conv  = [convergence_speed(h) for h in ga_histories]
    pso_conv = [convergence_speed(h) for h in pso_histories]

    ttest = welch_t_test(ga_fitnesses, pso_fitnesses)

    result = {
        "experiment": "GA vs PSO Comparison",
        "grid_size":  grid_size,
        "n_runs":     n_runs,
        "GA": {
            "fitnesses":        ga_fitnesses,
            "mean_fitness":     round(float(np.mean(ga_fitnesses)), 4),
            "std_fitness":      round(float(np.std(ga_fitnesses)), 4),
            "best_fitness":     round(max(ga_fitnesses), 4),
            "mean_time_s":      round(float(np.mean(ga_times)), 2),
            "convergence_gen":  ga_conv,
            "mean_convergence": round(float(np.mean(ga_conv)), 1),
            "histories":        ga_histories,
        },
        "PSO": {
            "fitnesses":        pso_fitnesses,
            "mean_fitness":     round(float(np.mean(pso_fitnesses)), 4),
            "std_fitness":      round(float(np.std(pso_fitnesses)), 4),
            "best_fitness":     round(max(pso_fitnesses), 4),
            "mean_time_s":      round(float(np.mean(pso_times)), 2),
            "convergence_iter": pso_conv,
            "mean_convergence": round(float(np.mean(pso_conv)), 1),
            "histories":        pso_histories,
        },
        "statistical_test": ttest,
        "winner": "GA" if np.mean(ga_fitnesses) > np.mean(pso_fitnesses) else "PSO",
    }

    _save("exp1_ga_vs_pso", result)
    return result


